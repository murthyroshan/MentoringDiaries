PORT=5000
# DB_PATH=./data/mentoring.db  (optional override; default is server/data/mentoring.db)

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant
AI_TIMEOUT_MS=5000

CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Number of proxy hops to trust for req.ip (only set when behind a reverse
# proxy / load balancer, e.g. 1). Leave unset when the server is exposed
# directly, otherwise clients can spoof X-Forwarded-For and bypass rate limits.
# TRUST_PROXY=1

# Set SEED_ON_EMPTY=true to allow auto-seeding demo accounts on an empty DB in
# production (off by default so known seed passwords are never provisioned).
# SEED_ON_EMPTY=false